# ============ 应用 ============
APP_NAME=MyFriend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
# 前端地址，用于 CORS
CORS_ORIGINS=http://localhost:5173

# ============ 安全 ============
# JWT 签名密钥，生产请改成随机长字符串
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# API Key 对称加密密钥（Fernet，44 位 base64），生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# ============ PostgreSQL ============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=myfriend
POSTGRES_PASSWORD=myfriend
POSTGRES_DB=myfriend
# 连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_STATEMENT_TIMEOUT_MS=60000

# ============ Elasticsearch ============
ES_HOST=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_MAX_RETRIES=3
ES_REQUEST_TIMEOUT=30
ES_MAX_CONNECTIONS=25

# ============ Neo4j ============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cometneo4j
NEO4J_MAX_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# ============ Redis / Celery ============
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============ 文件存储 ============
# 存储后端：local（本地目录）/ oss（阿里云对象存储）
STORAGE_BACKEND=local
STORAGE_DIR=./storage

# 阿里云 OSS 配置（STORAGE_BACKEND=oss 时填写）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=comet-files

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/myfriend.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
DB_ECHO=false

# ============ 知识库 RAG ============
EMBEDDING_DIMS=1024
