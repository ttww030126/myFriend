# ============ 根 .env.example（docker-compose 用）============
# 复制为 .env：  copy .env.example .env

# ---- 应用 ----
APP_NAME=myFriend
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173

# ---- 安全 ----
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# 生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# ---- PostgreSQL ----
POSTGRES_USER=myfriend
POSTGRES_PASSWORD=myfriend
POSTGRES_DB=myfriend

# ---- Neo4j ----
NEO4J_USER=neo4j
NEO4J_PASSWORD=myfriendneo4j

# 说明：容器间地址（POSTGRES_HOST/ES_HOST/NEO4J_URI/REDIS_URL 等）
# 已在 docker-compose.yml 的 environment 中覆盖为服务名，无需在此设置。
# 本地裸跑后端时，请用 api/.env.example 里的 localhost 配置。
